/dts-v1/;
/plugin/;

/ {
    compatible = "brcm,bcm2835";

    /* Enable the I2S peripheral */
    fragment@0 {
        target = <&i2s>;
        __overlay__ {
            status = "okay";
            #sound-dai-cells = <0>;
        };
    };

    /* Dummy codec — stands in for an external DAC that needs no driver */
    fragment@1 {
        target-path = "/";
        __overlay__ {
            codec_out: spdif-transmitter {
                compatible = "linux,spdif-dit";
                #sound-dai-cells = <0>;
                status = "okay";
            };
        };
    };

    /* Wire up I2S and the dummy codec into an ALSA sound card */
    fragment@2 {
        target = <&sound>;
        __overlay__ {
            compatible = "simple-audio-card";
            simple-audio-card,name = "rbpi-i2s";
            status = "okay";

            playback_link: simple-audio-card,dai-link@1 {
                format = "i2s";
                /* Codec is the bit-clock and frame-clock master */
                bitclock-master = <&p_codec_dai>;
                frame-master = <&p_codec_dai>;

                p_cpu_dai: cpu {
                    sound-dai = <&i2s>;
                    dai-tdm-slot-num = <2>;
                    dai-tdm-slot-width = <32>;
                };

                p_codec_dai: codec {
                    sound-dai = <&codec_out>;
                };
            };
        };
    };
};
